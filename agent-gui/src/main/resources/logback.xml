<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender: visible when launched from a terminal via gradle run -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{30} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      File appender: when the app is launched from Finder as a .app bundle,
      stdout/stderr go nowhere visible. Persist to ~/Library/Logs/FatherEyeAgent/agent.log
      so the user can inspect crashes after the fact.
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${user.home}/Library/Logs/FatherEyeAgent/agent.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${user.home}/Library/Logs/FatherEyeAgent/agent.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>5MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>30MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level %logger{40} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- The Anthropic SDK uses OkHttp under the hood; quiet its info noise. -->
    <logger name="okhttp3" level="WARN"/>
    <logger name="com.anthropic" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
